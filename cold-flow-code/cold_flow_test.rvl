#SENSOR MANIFEST
# HARDWARE:
# NI cDAQ-9189 chassis at 172.16.23.1
# Slot 1: NI 9482 — 4ch Relay Output (sv10–sv13)
# Slot 2: NI 9401 — 8ch High-Speed DIO (MBV_ox_run, MBV_fuel_run — servo PWM)
# Slot 3: NI 9482 — 4ch Relay Output (sv0–sv3)
# Slot 4: NI 9219 — 4ch Universal Input, strain gauge (LC_ox_tank)
# Slot 5: NI 9205 — 32ch Analog Input (PT_n2_fill, PT_ox_tank, PT_ox_fill, PT_fuel_tank, PT_chamber)
# Slot 8: NI 9213 — 16ch Thermocouple Input (TC0, Type K, degF)

#CONSTANTS
const CYCLE:float = 0.1
const MAX_SAFE_P:float = 1240.0
const WARN_P:float = 1150.0

#SERVO PWM CONSTANTS (MBV valve actuation via NI 9401)
const PULSE_PERIOD_MS:float = 5.0
const PULSE_WIDTH_MIN_MS:float = 0.5    #0 deg = fully closed
const PULSE_WIDTH_MAX_MS:float = 2.5    #180 deg = max travel
const PULSE_OPEN_FRACTION:float = 0.6   #60% of full travel = open position
const CLOSED_DUTY_CYCLE:float = PULSE_WIDTH_MIN_MS / PULSE_PERIOD_MS
var OPEN_DUTY_CYCLE:float = max(min(1.0, PULSE_OPEN_FRACTION), 0.0) * PULSE_WIDTH_MAX_MS / PULSE_PERIOD_MS
const RATE_ALPHA:float = 0.1    #EMA smoothing for rate traces (0=frozen, 1=raw, tune as needed)
const DEADBAND:float = 1.0      #PSI — changes smaller than this get suppressed, larger pass through instantly

#HARDWARE INPUTS
hwin |PT_n2_fill|:float    #NI 9205 slot 5 pt0 — N2 fill line (PSI)
hwin |PT_ox_tank|:float    #NI 9205 slot 5 pt1 — oxidizer tank (PSI)
hwin |PT_ox_fill|:float    #NI 9205 slot 5 pt2 — oxidizer fill line (PSI)
hwin |PT_fuel_tank|:float  #NI 9205 slot 5 pt3 — fuel tank (PSI)
hwin |PT_chamber|:float    #NI 9205 slot 5 pt4 — chamber (PSI)
hwin |TC0|:float           #NI 9213 slot 8 — thermocouple Type K (degF)
hwin |LC_ox_tank|:float    #NI 9219 slot 4 ch0 — ox tank load cell (lbs)
hwin |LoadCell1|:float     #NI 9219 slot 4 ch1
hwin |LoadCell2|:float     #NI 9219 slot 4 ch2
hwin |LoadCell3|:float     #NI 9219 slot 4 ch3

#HARDWARE OUTPUTS — Slot 2 NI 9401 (MBV_ox_run, MBV_fuel_run — servo PWM)
hwout |MBV_ox_run.command|:bool = True
hwout |MBV_ox_run.frequency|:float = 1.0 / (PULSE_PERIOD_MS / 1000.0)
hwout |MBV_ox_run.duty_cycle|:float = CLOSED_DUTY_CYCLE
hwout |MBV_fuel_run.command|:bool = True
hwout |MBV_fuel_run.frequency|:float = 1.0 / (PULSE_PERIOD_MS / 1000.0)
hwout |MBV_fuel_run.duty_cycle|:float = CLOSED_DUTY_CYCLE

#HARDWARE OUTPUTS — Slot 3 NI 9482 (sv0–sv3)
hwout |sv0|:bool = False   #SV_N2_fill
hwout |sv1|:bool = False   #SV_ox_vent
hwout |sv2|:bool = False   #SV_ox_fill
hwout |sv3|:bool = False   #SV_fuel_vent

#HARDWARE OUTPUTS — Slot 1 NI 9482 (sv10–sv13)
hwout |sv10|:bool = False  #ignition ematch
hwout |sv11|:bool = False
hwout |sv12|:bool = False
hwout |sv13|:bool = False

#SMOOTHED PRESSURE (for display — use these on gauges/traces, NOT the raw hwin channels)
sw |PT_n2_fill_S|:float = 0.0
sw |PT_ox_tank_S|:float = 0.0
sw |PT_ox_fill_S|:float = 0.0
sw |PT_fuel_tank_S|:float = 0.0
sw |PT_chamber_S|:float = 0.0

#DIAGNOSTIC CHANNELS
sw |System_Max_P|:float = 0.0
sw |PT_n2_fill_Prev|:float = 0.0
sw |PT_ox_tank_Prev|:float = 0.0
sw |PT_ox_fill_Prev|:float = 0.0
sw |PT_fuel_tank_Prev|:float = 0.0
sw |PT_chamber_Prev|:float = 0.0
sw |PT_n2_fill_Rate|:float = 0.0    #PSI/min (negative = venting)
sw |PT_ox_tank_Rate|:float = 0.0    #PSI/min (negative = venting)
sw |PT_ox_fill_Rate|:float = 0.0    #PSI/min (negative = venting)
sw |PT_fuel_tank_Rate|:float = 0.0  #PSI/min (negative = venting)
sw |PT_chamber_Rate|:float = 0.0    #PSI/min

#VALVE COMMAND CHANNELS (operator controlled)
sw |MBV_ox_run.open|:bool = False
sw |MBV_fuel_run.open|:bool = False
sw |SV_N2_fill.open|:bool = False
sw |SV_ox_vent.open|:bool = False
sw |SV_ox_fill.open|:bool = False
sw |SV_fuel_vent.open|:bool = False
sw |SV10.open|:bool = False
sw |SV11.open|:bool = False
sw |SV12.open|:bool = False
sw |SV13.open|:bool = False

#IGNITION (one-cycle pulse on sv10)
sw |Ignition_Fire_Cmd|:bool = False
sw |Ignition_Output|:bool = False

#ABORT CONTROL
sw |Abort_Active|:bool = False
sw |EStop_Cmd|:bool = False
sw |Reset_Abort|:bool = False

#CALIBRATION — operator-triggered baseline logging for filter tuning
sw |Cal_Cmd|:bool = False              #click to start 10s baseline recording
sw |Cal_Active|:bool = False
sw |Cal_Count|:float = 0.0
const CAL_CYCLES:float = 100.0        #10 seconds at 0.1s/cycle
#Logged channels (raw readings during calibration)
sw |Cal_PT_n2_fill|:float = 0.0
sw |Cal_PT_ox_tank|:float = 0.0
sw |Cal_PT_ox_fill|:float = 0.0
sw |Cal_PT_fuel_tank|:float = 0.0
sw |Cal_PT_chamber|:float = 0.0
sw |Cal_LC_ox_tank|:float = 0.0
sw |Cal_LoadCell1|:float = 0.0
sw |Cal_LoadCell2|:float = 0.0
sw |Cal_LoadCell3|:float = 0.0
sw |Cal_TC0|:float = 0.0
sw |Cal_Done|:bool = False            #indicator: recording complete, ready to export


#ALERTS — pressure warnings
alert warn_pt_n2_fill:
    severity = Severity.warning
    trigger = |PT_n2_fill| > WARN_P

alert warn_pt_ox_tank:
    severity = Severity.warning
    trigger = |PT_ox_tank| > WARN_P

alert warn_pt_ox_fill:
    severity = Severity.warning
    trigger = |PT_ox_fill| > WARN_P

alert warn_pt_fuel_tank:
    severity = Severity.warning
    trigger = |PT_fuel_tank| > WARN_P

alert warn_pt_chamber:
    severity = Severity.warning
    trigger = |PT_chamber| > WARN_P

#ALERTS — overpressure (critical)
alert overpressure_pt_n2_fill:
    severity = Severity.critical
    trigger = |PT_n2_fill| > MAX_SAFE_P

alert overpressure_pt_ox_tank:
    severity = Severity.critical
    trigger = |PT_ox_tank| > MAX_SAFE_P

alert overpressure_pt_ox_fill:
    severity = Severity.critical
    trigger = |PT_ox_fill| > MAX_SAFE_P

alert overpressure_pt_fuel_tank:
    severity = Severity.critical
    trigger = |PT_fuel_tank| > MAX_SAFE_P

alert overpressure_pt_chamber:
    severity = Severity.critical
    trigger = |PT_chamber| > MAX_SAFE_P


#MONITOR — diagnostics and abort
loop monitor:
    #SMOOTH RAW PRESSURE — soft adaptive filter: alpha = d²/(d²+DEADBAND²), update = d³/(d²+DEADBAND²)
    #Small changes (<1PSI) heavily suppressed, large changes pass through smoothly with no hard cutoff
    #EMA (RATE_ALPHA) on rates below provides a second layer for residual noise at higher pressures
    |PT_n2_fill_S| = |PT_n2_fill_S| + (|PT_n2_fill| - |PT_n2_fill_S|) * (|PT_n2_fill| - |PT_n2_fill_S|) * (|PT_n2_fill| - |PT_n2_fill_S|) / ((|PT_n2_fill| - |PT_n2_fill_S|) * (|PT_n2_fill| - |PT_n2_fill_S|) + DEADBAND * DEADBAND)
    |PT_ox_tank_S| = |PT_ox_tank_S| + (|PT_ox_tank| - |PT_ox_tank_S|) * (|PT_ox_tank| - |PT_ox_tank_S|) * (|PT_ox_tank| - |PT_ox_tank_S|) / ((|PT_ox_tank| - |PT_ox_tank_S|) * (|PT_ox_tank| - |PT_ox_tank_S|) + DEADBAND * DEADBAND)
    |PT_ox_fill_S| = |PT_ox_fill_S| + (|PT_ox_fill| - |PT_ox_fill_S|) * (|PT_ox_fill| - |PT_ox_fill_S|) * (|PT_ox_fill| - |PT_ox_fill_S|) / ((|PT_ox_fill| - |PT_ox_fill_S|) * (|PT_ox_fill| - |PT_ox_fill_S|) + DEADBAND * DEADBAND)
    |PT_fuel_tank_S| = |PT_fuel_tank_S| + (|PT_fuel_tank| - |PT_fuel_tank_S|) * (|PT_fuel_tank| - |PT_fuel_tank_S|) * (|PT_fuel_tank| - |PT_fuel_tank_S|) / ((|PT_fuel_tank| - |PT_fuel_tank_S|) * (|PT_fuel_tank| - |PT_fuel_tank_S|) + DEADBAND * DEADBAND)
    |PT_chamber_S| = |PT_chamber_S| + (|PT_chamber| - |PT_chamber_S|) * (|PT_chamber| - |PT_chamber_S|) * (|PT_chamber| - |PT_chamber_S|) / ((|PT_chamber| - |PT_chamber_S|) * (|PT_chamber| - |PT_chamber_S|) + DEADBAND * DEADBAND)

    |System_Max_P| = max(max(max(max(|PT_n2_fill|, |PT_ox_tank|), |PT_ox_fill|), |PT_fuel_tank|), |PT_chamber|)

    #PRESSURE RATE (PSI/min) — derived from smoothed signal, EMA'd again for trace display
    |PT_n2_fill_Rate| = RATE_ALPHA * ((|PT_n2_fill_S| - |PT_n2_fill_Prev|) / CYCLE * 60.0) + (1.0 - RATE_ALPHA) * |PT_n2_fill_Rate|
    |PT_ox_tank_Rate| = RATE_ALPHA * ((|PT_ox_tank_S| - |PT_ox_tank_Prev|) / CYCLE * 60.0) + (1.0 - RATE_ALPHA) * |PT_ox_tank_Rate|
    |PT_ox_fill_Rate| = RATE_ALPHA * ((|PT_ox_fill_S| - |PT_ox_fill_Prev|) / CYCLE * 60.0) + (1.0 - RATE_ALPHA) * |PT_ox_fill_Rate|
    |PT_fuel_tank_Rate| = RATE_ALPHA * ((|PT_fuel_tank_S| - |PT_fuel_tank_Prev|) / CYCLE * 60.0) + (1.0 - RATE_ALPHA) * |PT_fuel_tank_Rate|
    |PT_chamber_Rate| = RATE_ALPHA * ((|PT_chamber_S| - |PT_chamber_Prev|) / CYCLE * 60.0) + (1.0 - RATE_ALPHA) * |PT_chamber_Rate|
    |PT_n2_fill_Prev| = |PT_n2_fill_S|
    |PT_ox_tank_Prev| = |PT_ox_tank_S|
    |PT_ox_fill_Prev| = |PT_ox_fill_S|
    |PT_fuel_tank_Prev| = |PT_fuel_tank_S|
    |PT_chamber_Prev| = |PT_chamber_S|

    #E-STOP: operator triggers abort
    if |EStop_Cmd|:
        |Abort_Active| = True
        |EStop_Cmd| = False

    #ABORT RESPONSE: open vent paths, close fill/ignition paths
    if |Abort_Active|:
        |MBV_ox_run.open| = True
        |MBV_fuel_run.open| = True
        |SV_N2_fill.open| = False
        |SV_ox_vent.open| = True
        |SV_ox_fill.open| = False
        |SV_fuel_vent.open| = True
        |SV10.open| = False
        |SV11.open| = False
        |SV12.open| = False
        |SV13.open| = False
        |sv0| = False
        |sv1| = True
        |sv2| = False
        |sv3| = True
        |sv10| = False
        |sv11| = False
        |sv12| = False
        |sv13| = False

    #ABORT RESET
    if |Reset_Abort|:
        |Abort_Active| = False
        |Reset_Abort| = False

    #CALIBRATION — record baseline for filter tuning (no filtering applied, raw readings)
    if |Cal_Cmd|:
        |Cal_Cmd| = False
        |Cal_Active| = True
        |Cal_Count| = 0.0
        |Cal_Done| = False

    if |Cal_Active|:
        #Log raw (unfiltered) channel values
        |Cal_PT_n2_fill| = |PT_n2_fill|
        |Cal_PT_ox_tank| = |PT_ox_tank|
        |Cal_PT_ox_fill| = |PT_ox_fill|
        |Cal_PT_fuel_tank| = |PT_fuel_tank|
        |Cal_PT_chamber| = |PT_chamber|
        |Cal_LC_ox_tank| = |LC_ox_tank|
        |Cal_LoadCell1| = |LoadCell1|
        |Cal_LoadCell2| = |LoadCell2|
        |Cal_LoadCell3| = |LoadCell3|
        |Cal_TC0| = |TC0|
        |Cal_Count| = |Cal_Count| + 1.0

        if |Cal_Count| >= CAL_CYCLES:
            |Cal_Active| = False
            |Cal_Done| = True


#WRITE HARDWARE
loop write_hardware:
    #Ignition pulse — clear every cycle, fire on command (sv10)
    |Ignition_Output| = False
    if |Ignition_Fire_Cmd|:
        |Ignition_Fire_Cmd| = False
        |Ignition_Output| = True

    #MBV servo control (NI 9401 slot 2)
    if |MBV_ox_run.open|:
        |MBV_ox_run.duty_cycle| = OPEN_DUTY_CYCLE
    else:
        |MBV_ox_run.duty_cycle| = CLOSED_DUTY_CYCLE
    if |MBV_fuel_run.open|:
        |MBV_fuel_run.duty_cycle| = OPEN_DUTY_CYCLE
    else:
        |MBV_fuel_run.duty_cycle| = CLOSED_DUTY_CYCLE

    #Solenoid relay outputs (NI 9482 slot 3 + slot 1)
    |sv0| = |SV_N2_fill.open|
    |sv1| = |SV_ox_vent.open|
    |sv2| = |SV_ox_fill.open|
    |sv3| = |SV_fuel_vent.open|
    |sv10| = |Ignition_Output|
    |sv11| = |SV11.open|
    |sv12| = |SV12.open|
    |sv13| = |SV13.open|
