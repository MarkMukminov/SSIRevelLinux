#SENSOR MANIFEST
# HARDWARE:
# NI cDAQ-9189 chassis at 172.16.23.1
# Slot 1: NI 9482 — 4ch Relay Output (sv10–sv13)
# Slot 2: NI 9401 — 8ch High-Speed DIO (servo0, servo1)
# Slot 3: NI 9482 — 4ch Relay Output (sv0–sv3)
# Slot 4: NI 9219 — 4ch Universal Input, strain gauge (lc0–lc3)
# Slot 5: NI 9205 — 32ch Analog Input (pt0–pt31)
# Slot 8: NI 9213 — 16ch Thermocouple Input (tc0–tc15, Type K, degF)

#CONSTANTS
const CYCLE:float = 0.1
const MAX_SAFE_P:float = 1240.0
const WARN_P:float = 1150.0

#SERVO PWM CONSTANTS (MBV valve actuation via NI 9401)
const PULSE_PERIOD_MS:float = 5.0
const PULSE_WIDTH_MIN_MS:float = 0.5    #0 deg = fully closed
const PULSE_WIDTH_MAX_MS:float = 2.5    #180 deg = max travel
const PULSE_OPEN_FRACTION:float = 0.74  #74% of full travel = open position
const CLOSED_DUTY_CYCLE:float = PULSE_WIDTH_MIN_MS / PULSE_PERIOD_MS
var OPEN_DUTY_CYCLE:float = max(min(1.0, PULSE_OPEN_FRACTION), 0.0) * PULSE_WIDTH_MAX_MS / PULSE_PERIOD_MS

#HARDWARE INPUTS
hwin |pt0|:float   #NI 9205 slot 5 — oxidizer tank pressure (PSI)
hwin |pt1|:float   #NI 9205 slot 5 — fuel tank pressure (PSI)
hwin |pt2|:float   #NI 9205 slot 5 — secondary pressure (PSI)
hwin |tc0|:float   #NI 9213 slot 8 — thermocouple Type K (degF)
hwin |lc0|:float   #NI 9219 slot 4 — load cell ch0
hwin |lc1|:float   #NI 9219 slot 4 — load cell ch1
hwin |lc2|:float   #NI 9219 slot 4 — load cell ch2
hwin |lc3|:float   #NI 9219 slot 4 — load cell ch3

#HARDWARE OUTPUTS — Slot 2 NI 9401 (servo0, servo1 — MBV PWM)
hwout |servo0.command|:bool = True
hwout |servo0.frequency|:float = 1.0 / (PULSE_PERIOD_MS / 1000.0)
hwout |servo0.duty_cycle|:float = CLOSED_DUTY_CYCLE
hwout |servo1.command|:bool = True
hwout |servo1.frequency|:float = 1.0 / (PULSE_PERIOD_MS / 1000.0)
hwout |servo1.duty_cycle|:float = CLOSED_DUTY_CYCLE

#HARDWARE OUTPUTS — Slot 3 NI 9482 (sv0–sv3)
hwout |sv0|:bool = False
hwout |sv1|:bool = False
hwout |sv2|:bool = False
hwout |sv3|:bool = False

#HARDWARE OUTPUTS — Slot 1 NI 9482 (sv10–sv13)
hwout |sv10|:bool = False
hwout |sv11|:bool = False
hwout |sv12|:bool = False
hwout |sv13|:bool = False

#SENSOR READOUT CHANNELS
sw |PT_OT|:float = 0.0
sw |PT_FT|:float = 0.0
sw |PT2|:float = 0.0
sw |TC0|:float = 70.0
sw |LoadCell0|:float = 0.0
sw |LoadCell1|:float = 0.0
sw |LoadCell2|:float = 0.0
sw |LoadCell3|:float = 0.0
sw |System_Max_P|:float = 0.0
sw |PT_OT_Prev|:float = 0.0
sw |PT_FT_Prev|:float = 0.0
sw |PT2_Prev|:float = 0.0
sw |PT_OT_Rate|:float = 0.0   #PSI/min (negative = venting)
sw |PT_FT_Rate|:float = 0.0   #PSI/min (negative = venting)
sw |PT2_Rate|:float = 0.0     #PSI/min (negative = venting)

#VALVE COMMAND CHANNELS (operator controlled)
sw |MBV_O.open|:bool = False
sw |MBV_F.open|:bool = False
sw |SV0.open|:bool = False
sw |SV1.open|:bool = False
sw |SV3.open|:bool = False
sw |SV10.open|:bool = False
sw |SV11.open|:bool = False
sw |SV12.open|:bool = False
sw |SV13.open|:bool = False

#IGNITION (one-cycle pulse)
sw |Ignition_Fire_Cmd|:bool = False
sw |Ignition_Output|:bool = False

#ABORT CONTROL
sw |Abort_Active|:bool = False
sw |EStop_Cmd|:bool = False
sw |Reset_Abort|:bool = False


#ALERTS — pressure warnings
alert warn_pt_ot:
    severity = Severity.warning
    trigger = |PT_OT| > WARN_P

alert warn_pt_ft:
    severity = Severity.warning
    trigger = |PT_FT| > WARN_P

alert warn_pt2:
    severity = Severity.warning
    trigger = |PT2| > WARN_P

#ALERTS — overpressure (critical)
alert overpressure_pt_ot:
    severity = Severity.critical
    trigger = |PT_OT| > MAX_SAFE_P

alert overpressure_pt_ft:
    severity = Severity.critical
    trigger = |PT_FT| > MAX_SAFE_P

alert overpressure_pt2:
    severity = Severity.critical
    trigger = |PT2| > MAX_SAFE_P


#READ HARDWARE
loop read_hardware:
    |PT_OT| = |pt0|
    |PT_FT| = |pt1|
    |PT2| = |pt2|
    |TC0| = |tc0|
    |LoadCell0| = |lc0|
    |LoadCell1| = |lc1|
    |LoadCell2| = |lc2|
    |LoadCell3| = |lc3|


#MONITOR — diagnostics and abort
loop monitor:
    |System_Max_P| = max(max(|PT_OT|, |PT_FT|), |PT2|)

    #PRESSURE RATE (PSI/min)
    |PT_OT_Rate| = (|PT_OT| - |PT_OT_Prev|) / CYCLE * 60.0
    |PT_FT_Rate| = (|PT_FT| - |PT_FT_Prev|) / CYCLE * 60.0
    |PT2_Rate| = (|PT2| - |PT2_Prev|) / CYCLE * 60.0
    |PT_OT_Prev| = |PT_OT|
    |PT_FT_Prev| = |PT_FT|
    |PT2_Prev| = |PT2|

    #E-STOP: operator triggers abort
    if |EStop_Cmd|:
        |Abort_Active| = True
        |EStop_Cmd| = False

    #ABORT RESPONSE: close all valves and force hardware off
    if |Abort_Active|:
        |MBV_O.open| = False
        |MBV_F.open| = False
        |SV0.open| = False
        |SV1.open| = False
        |SV3.open| = False
        |SV10.open| = False
        |SV11.open| = False
        |SV12.open| = False
        |SV13.open| = False
        |sv0| = False
        |sv1| = False
        |sv2| = False
        |sv3| = False
        |sv10| = False
        |sv11| = False
        |sv12| = False
        |sv13| = False

    #ABORT RESET
    if |Reset_Abort|:
        |Abort_Active| = False
        |Reset_Abort| = False


#WRITE HARDWARE
loop write_hardware:
    #Ignition pulse — clear every cycle, fire on command
    |Ignition_Output| = False
    if |Ignition_Fire_Cmd|:
        |Ignition_Fire_Cmd| = False
        |Ignition_Output| = True

    #MBV servo control (NI 9401 slot 2)
    if |MBV_O.open|:
        |servo0.duty_cycle| = OPEN_DUTY_CYCLE
    else:
        |servo0.duty_cycle| = CLOSED_DUTY_CYCLE
    if |MBV_F.open|:
        |servo1.duty_cycle| = OPEN_DUTY_CYCLE
    else:
        |servo1.duty_cycle| = CLOSED_DUTY_CYCLE

    #Solenoid relay outputs (NI 9482 slot 3 + slot 1)
    |sv0| = |SV0.open|
    |sv1| = |SV1.open|
    |sv2| = |Ignition_Output|
    |sv3| = |SV3.open|
    |sv10| = |SV10.open|
    |sv11| = |SV11.open|
    |sv12| = |SV12.open|
    |sv13| = |SV13.open|
